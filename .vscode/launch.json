{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug CLI (ts-node)",
      "type": "node",
      "request": "launch",
      "program": "${workspaceFolder}/node_modules/ts-node/dist/bin.js",
      "args": ["src/cli.ts", "--source", "mongodb://localhost:27017", "--target", "mongodb://localhost:27017", "--db", "testdb", "--collection", "users"],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "internalConsoleOptions": "neverOpen"
    }
  ]
}
