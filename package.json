{
  "name": "mongo-schema-drift",
  "version": "0.0.2",
  "description": "Detect schema drift in MongoDB collections - infer schemas and compare across environments.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "mongo-schema-drift": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rimraf dist",
    "lint": "eslint 'src/**/*.ts' --ext .ts",
    "test": "jest",
    "prepare": "npm run build",
    "start": "node dist/cli.js",
    "dev": "ts-node src/cli.ts"
  },
  "keywords": [
    "mongodb",
    "schema",
    "drift",
    "cli",
    "schema-diff",
    "mern",
    "mongodb schema drift",
    "mongoose",
    "mongodb schema compare"
  ],
  "author": "Abhijeet Kumar Singh <kumar.abhijeetsingh20@gmail.com>",
  "license": "MIT",

  "repository": {
    "type": "git",
    "url": "https://github.com/abhinetics/mongo-schema-drift.git"
  },
  "homepage": "https://github.com/abhinetics/mongo-schema-drift#readme",
  "bugs": {
    "url": "https://github.com/abhinetics/mongo-schema-drift/issues"
  },

  "dependencies": {
    "mongodb": "^5.8.0",
    "yargs": "^17.7.2"
  },
  "devDependencies": {
    "@types/jest": "^29.5.2",
    "@types/node": "^20.3.1",
    "@typescript-eslint/eslint-plugin": "^6.9.0",
    "@typescript-eslint/parser": "^6.9.0",
    "eslint": "^8.37.0",
    "jest": "^29.5.0",
    "rimraf": "^5.0.0",
    "ts-jest": "^29.1.0",
    "ts-node": "^10.9.1",
    "typescript": "^5.1.6"
  }
}
